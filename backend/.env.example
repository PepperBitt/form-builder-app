# Copy this file to `.env` and fill in your own values.
# These environment variables are read by the backend at runtime.

# PostgreSQL connection string (Neon, Supabase, or local Postgres)
# Falls back to the hardcoded value in app/core/database.py if unset.
DATABASE_URL=postgresql://postgres:password@localhost:5432/formsdb


# JWT signing secret — CHANGE THIS before deploying
SECRET_KEY=your-super-secret-key-change-in-production

# Redis (optional — used for form caching)
REDIS_URL=redis://localhost:6379/0

# Local storage paths
UPLOAD_DIR=app/storage/uploads
EXPORT_DIR=app/storage/exports

# Google OAuth — obtain from https://console.cloud.google.com/
# Required for POST /api/auth/google
# Use the OAuth 2.0 Client ID for the web or mobile app that will sign in users.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Public base URL of this API (used in share links returned by the API)
BASE_URL=http://localhost:8000
