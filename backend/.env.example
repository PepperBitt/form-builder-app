# Copy this file to `.env` and fill in your own values.
# These environment variables are read by the backend at runtime.

# PostgreSQL connection string (Neon, Supabase, or local Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/formsdb

# JWT signing secret — CHANGE THIS before deploying
SECRET_KEY=your-super-secret-key-change-in-production

# Redis (optional — used for form caching)
REDIS_URL=redis://localhost:6379/0

# Local storage paths
UPLOAD_DIR=app/storage/uploads
EXPORT_DIR=app/storage/exports
